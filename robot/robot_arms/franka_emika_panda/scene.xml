<mujoco model="panda scene">
  <include file="panda_nohand.xml"/>
  <!-- <include file="panda.xml"/> -->

  <statistic center="0.3 0 0.35" extent="0.8" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <global azimuth="120" elevation="-20"/> 
    <!-- offheight="192" offwidth="640" -->
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"
      mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.0" dir="1 0 -1" directional="true"/>
    <light pos="0 0 1.0" dir="-1 0 -1" directional="true"/>
    <geom name="floor" size="2 2 0.2" type="plane" material="grid"/>
    <geom name="wall1" type="box" size="2 0.01 1" pos="0 2 0.9" material="grid"/>
    <geom name="wall2" type="box" size="0.01 2 1" pos="-2 0 0.9" material="grid"/>
    <geom name="wall3" type="box" size="0.01 2 1" pos="2 0 0.9" material="grid"/>

    <body name="target" pos="0.5 0 .5" quat="0 1 0 0" mocap="true">
      <site type="sphere" size="0.01" rgba="0 0 1 0" group="1" name="target_site"/>
    </body>

    <body name="target_for_reach" pos="0.5 0.2 0.4" quat="0 1 0 0" mocap="true" >
      <site type="sphere" size="0.04" rgba="0 1.0 0 1" group="1" name="target_for_reach_site"/>
      <geom type="sphere" size="0.04" rgba="0 1.0 0 1" group="1" name="target_for_reach_site"/>
    </body>
    <!-- Ground plane so objects don't fall infinitely -->
    <!-- <geom name="floor" type="plane" size="10 10 0.1" rgba="0.5 0.5 0.5 1"/> -->
    
    <!-- Vertical wall positioned at X=2, Y=0, spanning 2m high and 2m wide -->
  </worldbody>
</mujoco>
